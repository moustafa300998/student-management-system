generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. جدول المستخدمين (للدخول والتسجيل)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("student") // admin or student
  createdAt DateTime @default(now())
}

// 2. جدول الحلقات أو الفصول
model Class {
  id       Int       @id @default(autoincrement())
  name     String
  students Student[]
}

// 3. جدول الطلاب (الأساسي)
model Student {
  id          Int          @id @default(autoincrement())
  name        String
  level       String
  classId     Int?
  class       Class?       @relation(fields: [classId], references: [id], onDelete: SetNull) // لو مسحت الفصل، الطالب يفضل موجود
  attendances Attendance[]
  payments    Payment[]
  createdAt   DateTime     @default(now())

  @@index([name]) // تسريع البحث بالاسم
}

// 4. جدول الحضور والغياب
model Attendance {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  date      DateTime @default(now()) @db.Date // تخزين التاريخ فقط بدون الوقت لسهولة المقارنة

  @@index([studentId])
}

// 5. جدول المدفوعات
model Payment {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  amount    Float
  date      DateTime @default(now())

  @@index([studentId])
}